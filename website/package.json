{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "doppler run --mount .dev.vars --mount-format env -- wrangler dev",
    "deployment": "tsc --noEmit && wrangler deploy --env preview",
    "deployment:production": "tsc --noEmit && wrangler deploy",
    "secrets:prod": "doppler run -c production --mount .env.prod --mount-format env -- wrangler secret bulk .env.prod",
    "verify:slack-bridge": "tsx scripts/verify-slack-bridge.ts"
  },
  "dependencies": {
    "@slack/web-api": "^7.14.1",
    "better-auth": "^1.5.4",
    "db": "workspace:^",
    "discord-api-types": "^0.38.40",
    "discord-slack-bridge": "workspace:^",
    "spiceflow": "1.18.0-rsc.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260130.0",
    "tsx": "^4.21.0",
    "wrangler": "^4.61.1"
  }
}
