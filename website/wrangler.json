{
  "name": "kimaki-website",
  "main": "src/index.ts",
  "minify": true,
  "compatibility_flags": ["nodejs_compat"],
  "compatibility_date": "2025-04-01",
  "durable_objects": {
    "bindings": [
      {
        "name": "SLACK_GATEWAY",
        "class_name": "SlackBridgeDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v2",
      "new_sqlite_classes": ["SlackBridgeDO"]
    }
  ],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "fc242a96a2d5472bb5d6a84eabaab910"
    }
  ],
  "routes": [
    {
      "pattern": "kimaki.xyz/*",
      "zone_name": "kimaki.xyz"
    },
    {
      "pattern": "slack-gateway.kimaki.xyz/*",
      "zone_name": "kimaki.xyz"
    }
  ],
  "env": {
    "preview": {
      "name": "kimaki-website-preview",
      "durable_objects": {
        "bindings": [
          {
            "name": "SLACK_GATEWAY",
            "class_name": "SlackBridgeDO"
          }
        ]
      },
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "fc242a96a2d5472bb5d6a84eabaab910"
        }
      ],
      "routes": [
        {
          "pattern": "preview.kimaki.xyz/*",
          "zone_name": "kimaki.xyz"
        },
        {
          "pattern": "preview-slack-gateway.kimaki.xyz/*",
          "zone_name": "kimaki.xyz"
        }
      ]
    }
  }
}
