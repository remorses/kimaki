generator client {
  provider     = "prisma-client"
  output       = "src/generated"
  moduleFormat = "esm"
  runtime      = "workerd"
}

datasource db {
  provider = "postgresql"
}

// Matches the gateway-proxy's raw SQL schema in db_config.rs.
// The Rust proxy uses raw SQL (CREATE TABLE IF NOT EXISTS),
// Prisma manages the same table via db push for the website.
model gateway_clients {
  client_id  String // the kimaki client id. identifies the kimaki user that is connecting to the gateway
  secret     String // the secret, needed to authorize clients that connect to the gateway.
  guild_id   String // the guild the client installed. it is known thanks to the Discord install url state parameter and callback url
  updated_at DateTime? @default(now()) @db.Timestamptz

  discord_user discord_users? @relation(fields: [client_id], references: [client_id], onDelete: Cascade)

  @@id([client_id, guild_id])
}

// Discord user data collected during OAuth bot install flow.
// Populated from /users/@me after exchanging the authorization code.
// Linked to gateway_clients via client_id. Deleting a discord_user
// cascades to delete all their gateway_clients rows.
model discord_users {
  discord_id     String  @id // Discord user snowflake ID
  client_id      String  @unique // the kimaki client_id that installed the bot
  username       String // Discord username
  global_name    String? // Display name, can be null
  avatar         String? // Avatar hash, used to build avatar URL
  email          String? // Email address, requires email OAuth scope
  email_verified Boolean @default(false) // Whether the email is verified on Discord
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @db.Timestamptz

  gateway_clients gateway_clients[]
}
