generator client_node {
  provider     = "prisma-client"
  output       = "src/generated/node"
  moduleFormat = "esm"
  runtime      = "nodejs"
}

generator client_cloudflare {
  provider      = "prisma-client"
  output        = "src/generated/cloudflare"
  moduleFormat  = "esm"
  runtime       = "workerd"
  // "small" trades slightly slower query compilation for a much smaller WASM
  // blob (~900 KiB vs ~3.6 MiB with "fast"). Critical for CF Worker cold starts.
  compilerBuild = "small"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────────
// better-auth core tables
// These are required by better-auth for user/session/account management.
// See: https://www.better-auth.com/docs/concepts/database#core-schema
// ──────────────────────────────────────────────────────────────────

// @@map is required: better-auth expects lowercase table names.
// Without it Prisma creates PascalCase tables (User, Session, etc.)
// which causes "State not persisted correctly" errors on OAuth callback.
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  accounts       Account[]
  sessions       Session[]
  gatewayClients gateway_clients[]
  orgMemberships org_member[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ──────────────────────────────────────────────────────────────────
// Kimaki gateway tables
// ──────────────────────────────────────────────────────────────────

// Matches the gateway-proxy's raw SQL schema in db_config.rs.
// The Rust proxy uses raw SQL (CREATE TABLE IF NOT EXISTS),
// Prisma manages the same table via db push for the website.
// Slack bridge also reuses this table: `guild_id` stores Discord guild IDs in
// Discord mode and Slack team IDs in Slack mode. Website KV cache mirrors
// selected row fields for short-TTL auth/routing acceleration, but this table
// remains the canonical source of truth.
model gateway_clients {
  client_id     String // the kimaki client id. identifies the kimaki user that is connecting to the gateway
  secret        String // the secret, needed to authorize clients that connect to the gateway.
  guild_id      String // the guild the client installed. it is known thanks to the Discord install url state parameter and callback url
  platform      gateway_client_platform @default(discord)
  bot_token     String? // Slack installs store the workspace bot token here; Discord rows leave it null.
  reachable_url String? // When set, the gateway-proxy connects outbound to this URL's /gateway WS endpoint instead of waiting for the client to connect inbound.
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime? @default(now()) @db.Timestamptz

  user_id String?
  user    User? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([client_id, guild_id])
  @@index([user_id])
}

enum gateway_client_platform {
  discord
  slack
}

// ──────────────────────────────────────────────────────────────────
// Kimaki Pro: orgs, subscriptions, and API keys
// IDs are ULIDs generated in application code before insert.
// ──────────────────────────────────────────────────────────────────

model org {
  org_id             String   @id
  name               String
  stripe_customer_id String?  @unique
  created_at         DateTime @default(now()) @db.Timestamptz
  updated_at         DateTime @default(now()) @db.Timestamptz

  members       org_member[]
  subscriptions subscription[]
  api_keys      api_key[]
}

model org_member {
  org_id  String
  user_id String
  role    org_member_role @default(owner)

  org  org  @relation(fields: [org_id], references: [org_id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([org_id, user_id])
  @@index([user_id])
}

enum org_member_role {
  owner
  admin
  member
}

model subscription {
  subscription_id      String              @id // Stripe subscription id
  org_id               String
  product_id           String // Stripe product id
  price_id             String // Stripe price id
  price_name           String?
  customer_id          String? // Stripe customer id (denormalized)
  status               subscription_status
  interval             String? // month, year
  current_period_end   DateTime?           @db.Timestamptz
  cancel_at_period_end Boolean             @default(false)
  created_at           DateTime            @default(now()) @db.Timestamptz
  updated_at           DateTime            @default(now()) @db.Timestamptz

  org org @relation(fields: [org_id], references: [org_id], onDelete: Cascade)

  @@index([org_id])
}

enum subscription_status {
  active
  trialing
  canceled
  past_due
  incomplete
  incomplete_expired
  unpaid
  paused
}

model api_key {
  api_key_id String         @id
  key        String         @unique // SHA-256 hash for lookup
  key_prefix String // first 8 chars for display (kimaki_ab...)
  org_id     String
  name       String?
  status     api_key_status @default(active)
  created_at DateTime       @default(now()) @db.Timestamptz

  org org @relation(fields: [org_id], references: [org_id], onDelete: Cascade)

  @@index([org_id])
}

enum api_key_status {
  active
  revoked
}
