generator client_node {
  provider     = "prisma-client"
  output       = "src/generated/node"
  moduleFormat = "esm"
  runtime      = "nodejs"
}

generator client_cloudflare {
  provider      = "prisma-client"
  output        = "src/generated/cloudflare"
  moduleFormat  = "esm"
  runtime       = "workerd"
  // "small" trades slightly slower query compilation for a much smaller WASM
  // blob (~900 KiB vs ~3.6 MiB with "fast"). Critical for CF Worker cold starts.
  compilerBuild = "small"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────────
// better-auth core tables
// These are required by better-auth for user/session/account management.
// See: https://www.better-auth.com/docs/concepts/database#core-schema
// ──────────────────────────────────────────────────────────────────

// @@map is required: better-auth expects lowercase table names.
// Without it Prisma creates PascalCase tables (User, Session, etc.)
// which causes "State not persisted correctly" errors on OAuth callback.
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  accounts       Account[]
  sessions       Session[]
  gatewayClients gateway_clients[]
  cloudMachines  cloud_machines[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ──────────────────────────────────────────────────────────────────
// Kimaki gateway tables
// ──────────────────────────────────────────────────────────────────

// Matches the gateway-proxy's raw SQL schema in db_config.rs.
// The Rust proxy uses raw SQL (CREATE TABLE IF NOT EXISTS),
// Prisma manages the same table via db push for the website.
// Slack bridge also reuses this table: `guild_id` stores Discord guild IDs in
// Discord mode and Slack team IDs in Slack mode. Website KV cache mirrors
// selected row fields for short-TTL auth/routing acceleration, but this table
// remains the canonical source of truth.
model gateway_clients {
  client_id     String // the kimaki client id. identifies the kimaki user that is connecting to the gateway
  secret        String // the secret, needed to authorize clients that connect to the gateway.
  guild_id      String // the guild the client installed. it is known thanks to the Discord install url state parameter and callback url
  platform      gateway_client_platform @default(discord)
  bot_token     String? // Slack installs store the workspace bot token here; Discord rows leave it null.
  reachable_url String? // When set, the gateway-proxy connects outbound to this URL's /gateway WS endpoint instead of waiting for the client to connect inbound.
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime? @default(now()) @db.Timestamptz

  user_id String?
  user    User? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([client_id, guild_id])
}

enum gateway_client_platform {
  discord
  slack
}

// ──────────────────────────────────────────────────────────────────
// Kimaki Cloud tables
// ──────────────────────────────────────────────────────────────────

// Tracks Fly.io machines provisioned via the kimaki.dev dashboard.
// Each row represents one machine in a user's Fly app.
// The machine runs kimaki in gateway mode, connecting through the
// shared gateway-proxy with the stored client_id:client_secret.
model cloud_machines {
  id             String               @id @default(uuid())
  user_id        String
  fly_app_name   String               @unique
  fly_machine_id String?              @unique
  fly_volume_id  String?
  region         String
  cpu_kind       String               @default("shared")
  cpus           Int                  @default(1)
  memory_mb      Int                  @default(512)
  disk_size_gb   Int                  @default(5)
  status         cloud_machine_status @default(creating)
  client_id      String
  client_secret  String
  guild_id       String?
  error_message  String?
  created_at     DateTime             @default(now()) @db.Timestamptz
  updated_at     DateTime             @updatedAt     @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("cloud_machines")
}

enum cloud_machine_status {
  creating
  awaiting_authorization
  running
  stopped
  error
}
