{
  "name": "db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./src": {
      "types": "./src/prisma-node.ts",
      "workerd": {
        "types": "./src/prisma-cloudflare.ts",
        "default": "./src/prisma-cloudflare.ts"
      },
      "default": "./src/prisma-node.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./src/prisma.js": {
      "types": "./src/prisma-node.ts",
      "workerd": {
        "types": "./src/prisma-cloudflare.ts",
        "default": "./src/prisma-cloudflare.ts"
      },
      "default": "./src/prisma-node.ts"
    }
  },
  "scripts": {
    "dev": "prisma dev -n kimaki -d",
    "studio": "doppler run -c dev --command 'prisma studio --url $DATABASE_URL'",
    "push:dev": "doppler run -c dev --command 'prisma db push --url $DATABASE_URL && pnpm tsc'",
    "push:prod": "doppler run -c production --command 'prisma db push --url $DATABASE_URL && pnpm tsc'",
    "gen": "prisma generate && pnpm tsc",
    "postinstall": "prisma generate",
    "pull:prod": "doppler run -c production --command 'prisma db pull --url $DATABASE_URL && prisma generate'"
  },
  "devDependencies": {
    "prisma": "7.4.2"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "@types/pg": "^8.18.0",
    "pg": "^8.19.0"
  }
}
