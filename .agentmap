          install_database_objects: fn
          load_clients_snapshot: fn
          parse_gateway_clients_change_payload: fn
          refresh_clients_by_ids: fn
          run_poll_loop: fn
          run_realtime_loop: fn
          should_reject_stale_client_data: fn
          signal_initial_sync_ready: fn
